-- Slider Logic
local function updateSlider(percent)
	percent = math.clamp(percent, 0, 1)
	sliderKnob.Position = UDim2.new(percent, 0, 0.5, 0)
	local newSpeed = minSpeed + (maxSpeed - minSpeed) * percent
	currentSpeed = math.floor(newSpeed)
	humanoid.WalkSpeed = currentSpeed
	speedLabel.Text = "Speed: " .. currentSpeed
end

local function handleSliderInput(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		local trackPos = sliderTrack.AbsolutePosition
		local trackSize = sliderTrack.AbsoluteSize
		local relativeX = math.clamp((input.Position.X - trackPos.X) / trackSize.X, 0, 1)
		updateSlider(relativeX)

		local moveConn = UserInputService.InputChanged:Connect(function(moveInput)
			if moveInput.UserInputType == Enum.UserInputType.MouseMovement then
				relativeX = math.clamp((moveInput.Position.X - trackPos.X) / trackSize.X, 0, 1)
				updateSlider(relativeX)
			end
		end)

		local releaseConn
		releaseConn = UserInputService.InputEnded:Connect(function(releaseInput)
			if releaseInput.UserInputType == Enum.UserInputType.MouseButton1 then
				moveConn:Disconnect()
				releaseConn:Disconnect()
			end
		end)
	end
end

sliderTrack.InputBegan:Connect(handleSliderInput)
sliderKnob.InputBegan:Connect(handleSliderInput)

-- Set initial speed
updateSlider(0)

