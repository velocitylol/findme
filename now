-- Toggle creator
local function createToggle(text, toggleName, onToggle)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 55)
	btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
	btn.Text = text .. ": OFF"
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.Font = Enum.Font.GothamSemibold
	btn.TextSize = 18
	btn.Parent = ContentFrame
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = btn
	
	btn.MouseButton1Click:Connect(function()
		toggles[toggleName] = not toggles[toggleName]
		local state = toggles[toggleName]
		if state then
			btn.BackgroundColor3 = Color3.fromRGB(0, 200, 80)
			btn.Text = text .. ": ON"
		else
			btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
			btn.Text = text .. ": OFF"
		end
		if onToggle then onToggle(state) end
	end)
	return btn
end

-- Button creator
local function createButton(text, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 50)
	btn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
	btn.Text = text
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Font = Enum.Font.GothamSemibold
	btn.TextSize = 17
	btn.Parent = ContentFrame
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = btn
	
	btn.MouseButton1Click:Connect(callback)
	return btn
end

-- Create features
createToggle("Fly", "Fly", function(state) if state then startFly() else stopFly() end end)
createToggle("Noclip", "Noclip", function(state) if state then startNoclip() else stopNoclip() end end)
createToggle("Instant Interact", "InstantInteract", function(state)
	if state then applyInstantInteract() end
end)
createToggle("Instant Heal", "InstantHeal", function(state)
	if state then startHeal() else stopHeal() end
end)

createButton("Save Location", function()
	if rootPart then
		savedCFrame = rootPart.CFrame
		print("✅ Location saved!")
	end
end)

createButton("Teleport to Saved Location", function()
	if savedCFrame and rootPart then
		rootPart.CFrame = savedCFrame
		print("✅ Teleported!")
	end
end)

-- Toggle GUI with INSERT
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.Insert then
		ScreenGui.Enabled = not ScreenGui.Enabled
	end
end)

-- Re-apply heal on respawn
player.CharacterAdded:Connect(function(newChar)
	task.wait(1)
	local newHum = newChar:FindFirstChild("Humanoid")
	if newHum and toggles.InstantHeal then
		if healConn then healConn:Disconnect() end
		healConn = newHum.HealthChanged:Connect(function(health)
			if toggles.InstantHeal and health < newHum.MaxHealth then
				newHum.Health = newHum.MaxHealth
			end
		end)
	end
end)

