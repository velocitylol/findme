-- ✅ FIXED & OPTIMIZED FOR XENO EXECUTOR
-- The original didn't load because Xeno often blocks/hides CoreGui parenting.
-- Fixed by using PlayerGui + added safety waits + better character loading + debug prints

print("🔧 XENO HUB - Starting load...")

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

task.wait(0.5) -- Small delay to make sure everything is loaded in Xeno

-- States
local toggles = {Fly = false, Noclip = false, InstantInteract = false, InstantHeal = false}
local savedCFrame = nil
local character, rootPart, humanoid
local flySpeed = 80
local keys = {}

local function updateCharacter()
	character = player.Character or player.CharacterAdded:Wait()
	rootPart = character:WaitForChild("HumanoidRootPart", 5)
	humanoid = character:WaitForChild("Humanoid", 5)
	if not rootPart or not humanoid then
		warn("⚠️ Xeno Hub: Could not find character parts")
	end
	print("✅ Xeno Hub: Character loaded")
end
updateCharacter()
player.CharacterAdded:Connect(updateCharacter)

-- === FLY ===
local flyConn
local function startFly()
	if flyConn then return end
	humanoid.PlatformStand = true
	flyConn = RunService.Heartbeat:Connect(function()
		if not toggles.Fly or not rootPart then return end
		local move = Vector3.new()
		if keys.W then move += camera.CFrame.LookVector end
		if keys.S then move -= camera.CFrame.LookVector end
		if keys.A then move -= camera.CFrame.RightVector end
		if keys.D then move += camera.CFrame.RightVector end
		if keys.Space then move += Vector3.new(0,1,0) end
		if keys.LeftControl then move -= Vector3.new(0,1,0) end
		
		rootPart.AssemblyLinearVelocity = move.Magnitude > 0 and move.Unit * flySpeed or Vector3.new()
	end)
end
local function stopFly()
	if flyConn then flyConn:Disconnect() flyConn = nil end
	if humanoid then humanoid.PlatformStand = false end
	if rootPart then rootPart.AssemblyLinearVelocity = Vector3.new() end
end

-- === NOCLIP ===
local noclipConn
local function startNoclip()
	if noclipConn then return end
	noclipConn = RunService.Stepped:Connect(function()
		if not toggles.Noclip or not character then return end
		for _, part in pairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	end)
end
local function stopNoclip()
	if noclipConn then noclipConn:Disconnect() noclipConn = nil end
end

-- === INSTANT INTERACT ===
local function applyInstantInteract()
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			obj.HoldDuration = 0
		end
	end
end
workspace.DescendantAdded:Connect(function(obj)
	if toggles.InstantInteract and obj:IsA("ProximityPrompt") then
		obj.HoldDuration = 0
	end
end)

-- === INSTANT HEAL ===
local healConn
local function startHeal()
	if healConn then return end
	healConn = humanoid.HealthChanged:Connect(function(health)
		if toggles.InstantHeal and health < humanoid.MaxHealth then
			humanoid.Health = humanoid.MaxHealth
		end
	end)
end
local function stopHeal()
	if healConn then healConn:Disconnect() healConn = nil end
end

-- Key tracking
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	local keyName = input.KeyCode.Name
	if keyName == "W" or keyName == "A" or keyName == "S" or keyName == "D" or keyName == "Space" or keyName == "LeftControl" then
		keys[keyName] = true
	end
end)
UserInputService.InputEnded:Connect(function(input)
	local keyName = input.KeyCode.Name
	if keyName == "W" or keyName == "A" or keyName == "S" or keyName == "D" or keyName == "Space" or keyName == "LeftControl" then
		keys[keyName] = false
	end
end)

