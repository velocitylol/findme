-- ==================== FLY (LinearVelocity - no CFrame) ====================
local linearVel, attach
local function startFly()
	if linearVel then return end
	attach = Instance.new("Attachment")
	attach.Parent = rootPart

	linearVel = Instance.new("LinearVelocity")
	linearVel.Attachment0 = attach
	linearVel.MaxForce = 1e5
	linearVel.VectorVelocity = Vector3.new()
	linearVel.Parent = rootPart

	humanoid.PlatformStand = true

	local flyLoop = RunService.Heartbeat:Connect(function()
		if not toggles.Fly or not rootPart then return end
		local move = Vector3.new()
		if keys.W then move += camera.CFrame.LookVector end
		if keys.S then move -= camera.CFrame.LookVector end
		if keys.A then move -= camera.CFrame.RightVector end
		if keys.D then move += camera.CFrame.RightVector end
		if keys.Space then move += Vector3.new(0,1,0) end
		if keys.LeftControl then move -= Vector3.new(0,1,0) end

		linearVel.VectorVelocity = move.Magnitude > 0 and move.Unit * flySpeed or Vector3.new()
	end)
	table.insert(connections, flyLoop)
end

local function stopFly()
	toggles.Fly = false
	if linearVel then linearVel:Destroy() linearVel = nil end
	if attach then attach:Destroy() attach = nil end
	if humanoid then humanoid.PlatformStand = false end
	if rootPart then rootPart.AssemblyLinearVelocity = Vector3.new() end
end

-- ==================== NOCLIP (now properly resets when off) ====================
local noclipConn
local function startNoclip()
	if noclipConn then return end
	noclipConn = RunService.Stepped:Connect(function()
		if not toggles.Noclip or not character then return end
		for _, part in pairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	end)
end

local function resetCollisions()
	if character then
		for _, part in pairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = true
			end
		end
	end
end

local function stopNoclip()
	if noclipConn then 
		noclipConn:Disconnect() 
		noclipConn = nil 
	end
	resetCollisions()
end

-- ==================== INVISIBILITY ====================
local originalTransparency = {}
local function startInvisibility()
	if not character then return end
	originalTransparency = {}
	for _, obj in pairs(character:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
			originalTransparency[obj] = obj.Transparency
			obj.Transparency = 1
		elseif obj:IsA("Decal") then
			originalTransparency[obj] = obj.Transparency
			obj.Transparency = 1
		end
	end
end
local function stopInvisibility()
	for obj, trans in pairs(originalTransparency) do
		if obj and obj.Parent then obj.Transparency = trans end
	end
	originalTransparency = {}
end

-- ==================== INSTANT INTERACT (FIXED - stronger settings) ====================
local function applyInstantInteract()
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			obj.HoldDuration = 0
			obj.MaxActivationDistance = 1000
			obj.RequiresLineOfSight = false
		end
	end
end
workspace.DescendantAdded:Connect(function(obj)
	if toggles.InstantInteract and obj:IsA("ProximityPrompt") then
		obj.HoldDuration = 0
		obj.MaxActivationDistance = 1000
		obj.RequiresLineOfSight = false
	end
end)

-- ==================== INSTANT HEAL ====================
local healConn
local function startHeal()
	if healConn then return end
	healConn = humanoid.HealthChanged:Connect(function(health)
		if toggles.InstantHeal and health < humanoid.MaxHealth then
			humanoid.Health = humanoid.MaxHealth
		end
	end)
end
local function stopHeal()
	if healConn then healConn:Disconnect() healConn = nil end
end

-- ==================== FREEZE PLAYERS ====================
local freezeLoop
local function updateFreeze()
	if freezeLoop then freezeLoop:Disconnect() freezeLoop = nil end
	freezeLoop = RunService.Heartbeat:Connect(function()
		if not (toggles.FreezeAll or next(frozenPlayers)) then return end
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr == player then continue end
			local shouldFreeze = toggles.FreezeAll or frozenPlayers[plr.UserId]
			if shouldFreeze and plr.Character then
				local root = plr.Character:FindFirstChild("HumanoidRootPart")
				if root then
					root.AssemblyLinearVelocity = Vector3.new(0,0,0)
					root.AssemblyAngularVelocity = Vector3.new(0,0,0)
				end
			end
		end
	end)
end

local function togglePlayerFreeze(plr, state)
	if state then
		frozenPlayers[plr.UserId] = true
	else
		frozenPlayers[plr.UserId] = nil
	end
	updateFreeze()
end

