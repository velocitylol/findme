-- COMBAT TAB (Silent Aim + FOV Circle)
local CombatTab = Window:CreateTab("⚔️ Combat", 4483362458)

local silentAimEnabled = false
local fovValue = 300
local fovCircle = Drawing.new("Circle")
fovCircle.Thickness = 2
fovCircle.Color = Color3.fromRGB(255, 0, 255)
fovCircle.Transparency = 0.7
fovCircle.NumSides = 100
fovCircle.Radius = fovValue
fovCircle.Visible = false
fovCircle.Filled = false

-- Update FOV circle every frame
local circleConnection
CombatTab:CreateToggle({
    Name = "🔫 Silent Aim (Knife) + Visible FOV Circle",
    CurrentValue = false,
    Callback = function(val)
        silentAimEnabled = val
        fovCircle.Visible = val

        if val then
            -- Silent Aim logic from sneekygoober March 2026 script (hook RayCast + throw effect)
            spawn(function()
                local Players = game:GetService("Players")
                local plr = Players.LocalPlayer
                local cam = workspace.CurrentCamera
                local UIS = game:GetService("UserInputService")

                local ctea = plr.PlayerGui:FindFirstChild("GameUI") and plr.PlayerGui.GameUI:FindFirstChild("ClientMaster") and plr.PlayerGui.GameUI.ClientMaster:FindFirstChild("ClientTriggers") and plr.PlayerGui.GameUI.ClientMaster.ClientTriggers:FindFirstChild("CreateThrowEffectAsync")
                if not ctea then Rayfield:Notify({Title = "Silent Aim", Content = "GameUI not found - script may need update", Duration = 5}) return end

                local _, cf = pcall(require, plr.PlayerGui.GameUI.ClientMaster.CommonFunctions)

                local rp = RaycastParams.new()
                rp.FilterType = Enum.RaycastFilterType.Exclude
                rp.IgnoreWater = true

                local function isVisible(part, origin)
                    local char = plr.Character
                    if not (char and part) then return false end
                    rp.FilterDescendantsInstances = {char, workspace:FindFirstChild("WorldIgnore")}
                    local origin = origin or (char:FindFirstChild("Head") and char.Head.Position) or cam.CFrame.Position
                    local dir = part.Position - origin
                    local result = workspace:Raycast(origin, dir, rp)
                    if not result then return true end
                    return result.Instance:IsDescendantOf(part.Parent), result.Instance
                end

                local function getTarget(origin)
                    local cPart, cDistance = nil, fovValue
                    for _, player in Players:GetPlayers() do
                        if player == plr then continue end
                        local char = player.Character
                        if not char or char:FindFirstChildOfClass("ForceField") or (char:FindFirstChild("Humanoid") and char.Humanoid.Health <= 0) then continue end
                        local tPart = char:FindFirstChild("Head") or char.PrimaryPart or char:FindFirstChild("HumanoidRootPart")
                        if not tPart then continue end
                        local pos, onScreen = cam:WorldToViewportPoint(tPart.Position)
                        if not onScreen then continue end
                        local v = isVisible(tPart, origin)
                        if not v then continue end
                        local distance = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
                        if distance < cDistance then
                            cPart = tPart
                            cDistance = distance
                        end
                    end
                    return cPart
                end

                -- Hook RayCast (core silent aim)
                local oldRayCast
                oldRayCast = hookfunction(rawget(cf, "RayCast"), function(origin, _, ...)
                    local c = getTarget(origin)
                    if c then return oldRayCast(origin, c.Position, ...) end
                    return oldRayCast(origin, _, ...)
                end)

                -- Hook throw effect for knives
                ctea.OnInvoke = function(_, data, __, ___)
                    if data and data.Start and data.Target then
                        local c = getTarget(data.Start)
                        if c then
                            data.Target = c.Position
                        end
                    end
                    return data
                end

                -- FOV circle updater
                if circleConnection then circleConnection:Disconnect() end
                circleConnection = game:GetService("RunService").RenderStepped:Connect(function()
                    if silentAimEnabled then
                        fovCircle.Position = UIS:GetMouseLocation()
                        fovCircle.Radius = fovValue
                    end
                end)

                Rayfield:Notify({Title = "✅ Silent Aim ON", Content = "FOV circle visible • Knives now silent", Duration = 6})
            end)
        else
            if circleConnection then circleConnection:Disconnect() end
            fovCircle.Visible = false
            Rayfield:Notify({Title = "Silent Aim OFF", Content = "Hooks disabled", Duration = 3})
        end
    end
})

CombatTab:CreateSlider({
    Name = "FOV Circle Size (POV)",
    Range = {50, 800},
    Increment = 10,
    CurrentValue = 300,
    Callback = function(val)
        fovValue = val
        if fovCircle then fovCircle.Radius = val end
    end
})

-- VISUALS TAB (ESP from VardySc 2026 patterns)
local VisualsTab = Window:CreateTab("👁️ Visuals", 4483362458)

VisualsTab:CreateToggle({
    Name = "📦 Box ESP + Tracers",
    CurrentValue = false,
    Callback = function(val)
        if val then
            spawn(function()
                -- Box + Tracers ESP from public VardySc KAT script (March 2026 working)
                local Players = game:GetService("Players")
                local Camera = workspace.CurrentCamera
                local LocalPlayer = Players.LocalPlayer

                local function DrawESP(plr)
                    local Box = Drawing.new("Quad")
                    Box.Visible = false
                    Box.Color = Color3.fromRGB(255, 255, 255)
                    Box.Thickness = 2
                    Box.Transparency = 1

                    local Tracer = Drawing.new("Line")
                    Tracer.Visible = false
                    Tracer.Color = Color3.fromRGB(255, 0, 0)
                    Tracer.Thickness = 1

                    local function Update()
                        game:GetService("RunService").RenderStepped:Connect(function()
                            if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") and plr.Character.Humanoid.Health > 0 then
                                local rootPos, onScreen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
                                if onScreen then
                                    -- Box logic (simplified from public)
                                    local top = Camera:WorldToViewportPoint((plr.Character.Head.CFrame * CFrame.new(0, 2, 0)).p)
                                    local bottom = Camera:WorldToViewportPoint((plr.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)).p)
                                    Box.PointA = Vector2.new(top.X + 30, top.Y)
                                    Box.PointB = Vector2.new(bottom.X - 30, top.Y)
                                    Box.PointC = Vector2.new(bottom.X - 30, bottom.Y)
                                    Box.PointD = Vector2.new(top.X + 30, bottom.Y)
                                    Box.Visible = true

                                    -- Tracer
                                    Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                                    Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
                                    Tracer.Visible = true
                                else
                                    Box.Visible = false
                                    Tracer.Visible = false
                                end
                            else
                                Box.Visible = false
                                Tracer.Visible = false
                            end
                        end)
                    end
                    Update()
                end

                for _, v in Players:GetPlayers() do
                    if v ~= LocalPlayer then DrawESP(v) end
                end
                Players.PlayerAdded:Connect(function(v) DrawESP(v) end)
            end)
            Rayfield:Notify({Title = "ESP ON", Content = "Box + Tracers active", Duration = 4})
        else
            Rayfield:Notify({Title = "ESP OFF", Content = "Drawing removed", Duration = 3})
        end
    end
})

