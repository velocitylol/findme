local function refreshPlayerList()
	for _, child in pairs(playerListFrame:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == player then continue end
		local pBtn = Instance.new("TextButton")
		pBtn.Size = UDim2.new(1, 0, 0, 42)
		pBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
		pBtn.Text = plr.Name .. ": OFF"
		pBtn.TextColor3 = Color3.new(1,1,1)
		pBtn.Font = Enum.Font.GothamSemibold
		pBtn.TextSize = 16
		pBtn.Parent = playerListFrame
		
		local pc = Instance.new("UICorner")
		pc.CornerRadius = UDim.new(0, 8)
		pc.Parent = pBtn
		
		local isSelected = false
		pBtn.MouseButton1Click:Connect(function()
			isSelected = not isSelected
			togglePlayerFreeze(plr, isSelected)
			pBtn.Text = plr.Name .. (isSelected and ": ON" or ": OFF")
			pBtn.BackgroundColor3 = isSelected and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(50, 50, 50)
		end)
	end
end

Players.PlayerAdded:Connect(refreshPlayerList)
