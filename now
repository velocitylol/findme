-- VISUALS TAB - FIXED ESP
local VisualsTab = Window:CreateTab("👁️ Visuals", 4483362458)

local espConnections = {}
VisualsTab:CreateToggle({
    Name = "📦 Box ESP + Tracers",
    CurrentValue = false,
    Callback = function(val)
        if val then
            spawn(function()
                local Players = game:GetService("Players")
                local Camera = workspace.CurrentCamera
                local LocalPlayer = Players.LocalPlayer

                local function DrawESP(plr)
                    if plr == LocalPlayer then return end

                    local Box = Drawing.new("Quad")
                    Box.Visible = false
                    Box.Color = Color3.fromRGB(255, 255, 255)
                    Box.Thickness = 2
                    Box.Transparency = 1

                    local Tracer = Drawing.new("Line")
                    Tracer.Visible = false
                    Tracer.Color = Color3.fromRGB(255, 0, 0)
                    Tracer.Thickness = 1

                    local connection
                    connection = game:GetService("RunService").RenderStepped:Connect(function()
                        if not val then -- toggle off cleanup
                            Box.Visible = false
                            Tracer.Visible = false
                            connection:Disconnect()
                            return
                        end

                        local char = plr.Character
                        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                            local rootPos, onScreen = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
                            if onScreen then
                                -- Box (fixed positioning)
                                local top = Camera:WorldToViewportPoint((char.Head.CFrame * CFrame.new(0, 2, 0)).p)
                                local bottom = Camera:WorldToViewportPoint((char.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)).p)
                                Box.PointA = Vector2.new(top.X + 30, top.Y)
                                Box.PointB = Vector2.new(bottom.X - 30, top.Y)
                                Box.PointC = Vector2.new(bottom.X - 30, bottom.Y)
                                Box.PointD = Vector2.new(top.X + 30, bottom.Y)
                                Box.Visible = true

                                -- Tracer from center bottom
                                Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                                Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
                                Tracer.Visible = true
                            else
                                Box.Visible = false
                                Tracer.Visible = false
                            end
                        else
                            -- INSTANT HIDE ON DEATH (no ghosting or tracing)
                            Box.Visible = false
                            Tracer.Visible = false
                        end
                    end)

                    table.insert(espConnections, connection)
                end

                for _, v in Players:GetPlayers() do
                    DrawESP(v)
                end
                Players.PlayerAdded:Connect(DrawESP)
            end)
            Rayfield:Notify({Title = "ESP ON", Content = "Box + Tracers • Instant death cleanup", Duration = 4})
        else
            for _, conn in espConnections do
                if conn then conn:Disconnect() end
            end
            espConnections = {}
            Rayfield:Notify({Title = "ESP OFF", Content = "All drawings removed", Duration = 3})
        end
    end
})

