player.CharacterAdded:Connect(function(newChar)
	task.wait(1)
	local newHum = newChar:FindFirstChild("Humanoid")
	if newHum then
		newHum.WalkSpeed = walkSpeedValue
		if toggles.InstantHeal then
			if healConn then healConn:Disconnect() end
			healConn = newHum.HealthChanged:Connect(function(health)
				if toggles.InstantHeal and health < newHum.MaxHealth then
					newHum.Health = newHum.MaxHealth
				end
			end)
		end
	end
	if toggles.Invisibility then
		character = newChar
		rootPart = newChar:WaitForChild("HumanoidRootPart")
		startInvisibility()
	end
end)

