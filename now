-- =============================================
-- HITBOX EXPANDER (Head only, up to 20 studs)
-- =============================================
local hitboxEnabled = false
local hitboxSize = 10
local originalSizes = {}
local hitboxConnection

local function restoreHitboxes()
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= game.Players.LocalPlayer and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head and originalSizes[plr] then
                head.Size = originalSizes[plr]
                head.Transparency = 0
                head.CanCollide = true
            end
        end
    end
end

local function expandHitboxes()
    if hitboxConnection then hitboxConnection:Disconnect() end
    hitboxConnection = game:GetService("RunService").RenderStepped:Connect(function()
        for _, plr in ipairs(game.Players:GetPlayers()) do
            if plr ~= game.Players.LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
                local head = plr.Character.Head
                if not originalSizes[plr] then
                    originalSizes[plr] = head.Size
                end
                head.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                head.Transparency = 1 -- fully invisible
                head.CanCollide = false -- prevents physics bugs / clipping errors
            end
        end
    end)
end

MainTab:CreateToggle({
    Name = "Hitbox Expander (Head)",
    CurrentValue = false,
    Flag = "HitboxToggle",
    Callback = function(Value)
        hitboxEnabled = Value
        if Value then
            expandHitboxes()
        else
            if hitboxConnection then hitboxConnection:Disconnect() end
            restoreHitboxes()
            originalSizes = {}
        end
    end,
})

MainTab:CreateSlider({
    Name = "Hitbox Size (Studs)",
    Range = {0, 20},
    Increment = 0.1,
    CurrentValue = 10,
    Flag = "HitboxSize",
    Callback = function(Value)
        hitboxSize = Value
        if hitboxEnabled then
            -- live update
            for _, plr in ipairs(game.Players:GetPlayers()) do
                if plr ~= game.Players.LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
                    plr.Character.Head.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                end
            end
        end
    end,
})

